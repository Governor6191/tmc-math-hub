    {
      "id": "calculus-ii-integration-techniques-021",
      "stem": "Evaluate $\\displaystyle\\int \\frac{\\ln x}{x}\\,dx$.",
      "options": [
        "$\\left(\\ln x\\right)^2 + C$",
